# ─────────────────────────────────────────────────────────────
# UNI-THRIVE — Environment Variables
# Copy this file to .env.local and edit as needed
# ─────────────────────────────────────────────────────────────

# Demo mode — set to true to run with 100% mock data (no Supabase needed)
NEXT_PUBLIC_DEMO_MODE=true

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — OPTIONAL when DEMO_MODE=true
# Get these from https://supabase.com/dashboard/project/_/settings/api
# Leave as-is below to run without Supabase (dummy values are safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
